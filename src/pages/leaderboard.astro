---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeaderboardTable from '@/components/leaderboard/LeaderboardTable';
---

<BaseLayout
  title="Classements - Les Ombres du Son"
  description="Découvrez les meilleurs joueurs de Les Ombres du Son et leurs performances"
>
  <main class="min-h-screen bg-bg-light py-12">
    <div class="container-custom px-4">
      {/* Header */}
      <div class="text-center mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-gray-600 hover:text-primary transition-colors mb-6"
        >
          <svg class="w-5 h-5" fill="none" strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
          Retour à l'expérience
        </a>

        <h1 class="display-text text-display-sm md:text-display-md mb-4">
          Classements
        </h1>
        <p class="body-text text-body-lg text-gray-600 max-w-2xl mx-auto">
          Découvrez les meilleurs joueurs et leurs performances
        </p>
      </div>

      {/* Leaderboard component */}
      <LeaderboardTable client:load />
    </div>
  </main>
</BaseLayout>
